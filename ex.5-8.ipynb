   "outputs": [],
   "source": [
    "def f(x):\n",
    "    return (x-3)**2 + 4\n",
    "\n",
    "def dx_f(x): #도함수라는 뜻\n",
    "    return 2*(x-3)\n",
    "\n",
    "\n",
    "L = 0.001\n",
    "iterations = 10\n",
    "\n",
    "x = random.randint(-15,15)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eb5d4278-b7e4-4bb7-9240-9b40289001a9",
